{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reference provenance",
  "type": "object",
  "required": ["description", "references"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "url",
          "license",
          "commit",
          "copiedSource",
          "usedFor",
          "requiredDocs"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "kind": {
            "type": "string",
            "enum": [
              "api-and-registry-reference",
              "dependency",
              "implementation-reference",
              "research-trail",
              "standards-reference",
              "visual-reference"
            ]
          },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "license": {
            "type": "string",
            "minLength": 2
          },
          "commit": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{40}$"
          },
          "copiedSource": {
            "type": "boolean",
            "const": false
          },
          "usedFor": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "requiredDocs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    }
  }
}
