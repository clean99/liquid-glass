{
  "name": "@clean99/liquid-glass",
  "version": "0.1.0",
  "description": "Refractive Liquid Glass components for React, built on @hashintel/refractive with accessible fallbacks.",
  "type": "module",
  "license": "MIT",
  "author": "Koh Hom",
  "homepage": "https://github.com/clean99/liquid-glass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clean99/liquid-glass.git"
  },
  "bugs": {
    "url": "https://github.com/clean99/liquid-glass/issues"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "liquid-glass",
    "glassmorphism",
    "refractive",
    "storybook",
    "accessibility"
  ],
  "packageManager": "pnpm@11.5.2",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "registry",
    "registry.json",
    "schema",
    "README.md",
    "LICENSE",
    "ATTRIBUTIONS.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && node scripts/copy-css.mjs",
    "changeset": "changeset",
    "clean": "rm -rf dist coverage",
    "dev": "storybook dev -p 6006",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "storybook:build": "storybook build --quiet",
    "test": "vitest run",
    "test:a11y": "pnpm test:storybook",
    "test:components": "vitest run --passWithNoTests",
    "test:kube-reference": "pnpm build && rm -rf storybook-static-kube-reference && storybook build --quiet --output-dir storybook-static-kube-reference && STORYBOOK_STATIC_DIR=storybook-static-kube-reference node scripts/compare-kube-reference.mjs; status=$?; rm -rf storybook-static-kube-reference; exit $status",
    "test:inventory": "node scripts/validate-component-inventory.mjs",
    "test:package": "pnpm build && node tests/package-exports.mjs",
    "test:physics": "vitest run tests/refraction-physics.test.ts",
    "test:storybook": "pnpm build && rm -rf storybook-static-behavior && storybook build --quiet --output-dir storybook-static-behavior && STORYBOOK_STATIC_DIR=storybook-static-behavior node scripts/verify-enhanced-storybook.mjs && STORYBOOK_STATIC_DIR=storybook-static-behavior node scripts/verify-liquid-behavior.mjs; status=$?; rm -rf storybook-static-behavior; exit $status",
    "test:unit": "vitest run",
    "test:visual": "playwright test tests/visual --config=playwright.config.ts",
    "test:visual:update": "playwright test tests/visual --config=playwright.config.ts --update-snapshots",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:inventory && pnpm test:unit && pnpm test:components && pnpm test:physics && pnpm test:storybook && pnpm build && pnpm test:package"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@hashintel/refractive": "0.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "10.4.3",
    "@storybook/addon-docs": "10.4.3",
    "@storybook/nextjs-vite": "^10.4.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "next": "16.2.9",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  }
}
